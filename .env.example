# Environment Variables Template for HIS Frontend
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_AUTH_ENDPOINT=/auth/login

# Application Configuration
VITE_APP_NAME=Health Insurance System
VITE_APP_VERSION=1.0.0

# Authentication Configuration
VITE_JWT_SECRET_KEY=your-jwt-secret-key-here
VITE_SESSION_TIMEOUT=3600

# Third-party Services (if any)
VITE_ANALYTICS_ID=your-analytics-id
VITE_ERROR_REPORTING_KEY=your-error-reporting-key

# Development Configuration
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Note: Never commit the actual .env file to version control
# All sensitive values should be stored securely and not hardcoded